position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"MBOdF7YGtU"}],"identifier":"id-6-distributions-histograms","label":"6. Distributions — Histograms","html_id":"id-6-distributions-histograms","implicit":true,"key":"a5TYVpC2Np"}],"key":"hJOcQbYHxY"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-03-21T14:12:00.702916Z","start_time":"2026-03-21T14:11:54.269237Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"ret_df = df[df[\"log_return\"] != 0]\nprint(f\"Seconds with non-zero log_return: {len(ret_df):,} ({len(ret_df)/len(df)*100:.1f}%)\")\n\nn_syms = len(SYMBOLS)\nncols  = 3\nnrows  = (n_syms + ncols - 1) // ncols\nfig, axes = plt.subplots(nrows, ncols, figsize=(14, 4 * nrows))\n\nfor ax, sym in zip(axes.flat, SYMBOLS):\n    vals = ret_df.loc[ret_df[\"symbol\"] == sym, \"log_return\"].dropna()\n    if vals.empty:\n        ax.set_title(f\"{sym} (no data)\")\n        continue\n    vals.hist(bins=100, ax=ax, edgecolor=\"none\", alpha=0.85)   # pandas .hist()\n    ax.set_title(f\"{sym}  (skew={vals.skew():.2f}, kurt={vals.kurtosis():.1f})\")\n    ax.set_xlabel(\"log_return\")\nfor ax in axes.flat[n_syms:]:\n    ax.set_visible(False)\n\nplt.suptitle(\"1-second log return distribution by symbol\")\nplt.tight_layout()\nplt.show()\n\n# RV distribution\nrv_cols = [c for c in [\"rv_past_60\", \"rv_next_60\", \"rv_next_300\"] if c in df.columns]\nrv_df   = df[df[\"rv_past_60\"] > 0]\nfig, axes = plt.subplots(1, len(rv_cols), figsize=(5 * len(rv_cols), 4))\nif len(rv_cols) == 1:\n    axes = [axes]\nfor ax, col in zip(axes, rv_cols):\n    np.log1p(rv_df[col].dropna()).hist(bins=80, ax=ax, edgecolor=\"none\", alpha=0.85)\n    ax.set_title(f\"log1p({col})\")\n    ax.set_xlabel(\"log1p(RV)\")\nplt.suptitle(\"Realized Volatility distributions (log scale)\")\nplt.tight_layout()\nplt.show()","key":"BTBErcpiUQ"},{"type":"outputs","id":"qw5G_K_ECcE-mheAAudk2","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"Seconds with non-zero log_return: 773,184 (2.7%)\n"},"children":[],"key":"mpcYAOqBVz"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1680x1440 with 9 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"4e44e5d15d4880de1a0b3a690e108555","path":"/cme-vol-research.github.io/build/4e44e5d15d4880de1a0b3a690e108555.png"}}},"children":[],"key":"A2K2iPjXzW"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1800x480 with 3 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"7eb2be7baf4541f4fdc74e8f2cede6c7","path":"/cme-vol-research.github.io/build/7eb2be7baf4541f4fdc74e8f2cede6c7.png"}}},"children":[],"key":"wjw3xBnlZ9"}],"key":"kypTMhUsq7"}],"key":"th0epzMY3R"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"7. Box Plots — Distributions Across Groups","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"NhulEf8lNa"}],"identifier":"id-7-box-plots-distributions-across-groups","label":"7. Box Plots — Distributions Across Groups","html_id":"id-7-box-plots-distributions-across-groups","implicit":true,"key":"gC0guG5yT8"}],"key":"SLYXNfNyBn"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-03-21T14:12:17.034478Z","start_time":"2026-03-21T14:12:00.734616Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"# rv_past_60 by symbol — box plot (non-zero rows, log scale)\nfig, ax = plt.subplots(figsize=(11, 4))\nsns.boxplot(data=rv_df, x=\"symbol\", y=\"rv_past_60\", palette=\"tab10\",\n            showfliers=False, ax=ax)\nax.set_yscale(\"log\")\nax.set_title(\"rv_past_60 by symbol (log scale, outliers hidden)\")\nax.set_xlabel(\"symbol\")\nax.set_ylabel(\"rv_past_60\")\nplt.tight_layout()\nplt.show()\n\n# n_events by symbol — box plot (active seconds only)\nfig, ax = plt.subplots(figsize=(11, 4))\nsns.boxplot(data=df[df[\"n_events\"] > 0], x=\"symbol\", y=\"n_events\", palette=\"tab10\",\n            showfliers=False, ax=ax)\nax.set_title(\"n_events per second by symbol (active seconds only, outliers hidden)\")\nax.set_xlabel(\"symbol\")\nax.set_ylabel(\"n_events\")\nplt.tight_layout()\nplt.show()","key":"EbLWRtZXZr"},{"type":"outputs","id":"FQqlKxGN3uWeWgMoqBBIg","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1320x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"94ccffdf888f260b79606cf24106ad44","path":"/cme-vol-research.github.io/build/94ccffdf888f260b79606cf24106ad44.png"}}},"children":[],"key":"XBC0aYPxM9"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1320x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"1dc3d04daf9f59919a99dd13f5ac5132","path":"/cme-vol-research.github.io/build/1dc3d04daf9f59919a99dd13f5ac5132.png"}}},"children":[],"key":"e1UD7hYAhA"}],"key":"D10gBCsziR"}],"key":"idUwKiuI4Y"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"8. Correlation Matrix","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"hN9LDtPRCW"}],"identifier":"id-8-correlation-matrix","label":"8. Correlation Matrix","html_id":"id-8-correlation-matrix","implicit":true,"key":"iOCvzwonp8"}],"key":"R0yMR2mDQN"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-03-21T14:12:22.594159Z","start_time":"2026-03-21T14:12:17.061376Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"corr_cols = [\n    \"n_events\", \"n_trade\", \"n_add\", \"n_cancel\",\n    \"log_return\", \"rv_past_60\", \"rv_next_60\", \"rv_next_300\",\n    \"order_imbalance_60\", \"size_imbalance_60\", \"ret_std_60\",\n]\ncorr_cols = [c for c in corr_cols if c in df.columns]\n\ncorr_matrix = df[corr_cols].corr()\n\nfig, ax = plt.subplots(figsize=(10, 8))\nsns.heatmap(\n    corr_matrix, annot=True, fmt=\".2f\", cmap=\"RdBu_r\",\n    center=0, vmin=-1, vmax=1, linewidths=0.4,\n    annot_kws={\"size\": 8}, ax=ax\n)\nax.set_title(\"Pearson correlation matrix — key features and targets\")\nplt.tight_layout()\nplt.show()","key":"ignXw6LwvM"},{"type":"outputs","id":"8mE9td9eQ7-JCkDWsw0GV","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1200x960 with 2 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"93dbb21cda5332d7196560f3a5565d6e","path":"/cme-vol-research.github.io/build/93dbb21cda5332d7196560f3a5565d6e.png"}}},"children":[],"key":"JZQv5DjIMw"}],"key":"LugzWi5MhR"}],"key":"SsUu0hSKzc"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"9. Grouped Aggregations — Order Flow","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"ga6VKOSq9P"}],"identifier":"id-9-grouped-aggregations-order-flow","label":"9. Grouped Aggregations — Order Flow","html_id":"id-9-grouped-aggregations-order-flow","implicit":true,"key":"SEHdKR4rQp"}],"key":"uGx61WfrMs"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-03-21T14:12:25.003128Z","start_time":"2026-03-21T14:12:22.610804Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"flow_cols = [\"n_events\", \"n_add\", \"n_cancel\", \"n_modify\", \"n_trade\", \"n_fill\"]\n\n# mean and median per symbol\ndf.groupby(\"symbol\")[flow_cols].agg([\"mean\", \"median\"]).round(2)\n\n# event mix — % of total events per type\naction_pct = df.groupby(\"symbol\")[flow_cols].sum()\naction_pct = action_pct.div(action_pct.sum(axis=1), axis=0) * 100\n\naction_pct.plot(\n    kind=\"bar\", stacked=True, figsize=(11, 4),\n    edgecolor=\"none\", title=\"Order event mix by symbol (% of total events)\"\n)\nplt.ylabel(\"%\")\nplt.xticks(rotation=30)\nplt.legend(bbox_to_anchor=(1.01, 1), loc=\"upper left\", fontsize=8)\nplt.tight_layout()\nplt.show()","key":"VxOsAzwqUW"},{"type":"outputs","id":"NglH6_63kkhe7Y-Tplv9G","children":[{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1320x480 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"b4f782d36f095432ace9464fd62f1ab1","path":"/cme-vol-research.github.io/build/b4f782d36f095432ace9464fd62f1ab1.png"}}},"children":[],"key":"tSYNOKstgj"}],"key":"WhojW90rA0"}],"key":"wGfMUVKLGU"},{"type":"block","kind":"notebook-content","children":[{"type":"heading","depth":2,"position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"children":[{"type":"text","value":"10. Time Series — Sample Session","position":{"start":{"line":1,"column":1},"end":{"line":1,"column":1}},"key":"yHSQLCgu7q"}],"identifier":"id-10-time-series-sample-session","label":"10. Time Series — Sample Session","html_id":"id-10-time-series-sample-session","implicit":true,"key":"D45nN6efcr"},{"type":"paragraph","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"children":[{"type":"text","value":"Visual sanity check: price continuity, log return spikes, RV envelope, event activity.","position":{"start":{"line":3,"column":1},"end":{"line":3,"column":1}},"key":"koOpZfmgGX"}],"key":"lBSskpk2jz"}],"key":"tmTExmP469"},{"type":"block","kind":"notebook-code","data":{"ExecuteTime":{"end_time":"2026-03-21T14:12:28.143476Z","start_time":"2026-03-21T14:12:25.018189Z"}},"children":[{"type":"code","lang":"python","executable":true,"value":"PLOT_SYMBOL = \"6E.c.0\"   # ← change as desired\n\nlatest_session = df[df[\"symbol\"] == PLOT_SYMBOL][\"session_date\"].max()\nsess = (\n    df[(df[\"symbol\"] == PLOT_SYMBOL) & (df[\"session_date\"] == latest_session)]\n    .sort_values(\"second_bucket\")\n    .set_index(\"second_bucket\")\n)\nprint(f\"{PLOT_SYMBOL} — {latest_session}  ({len(sess):,} seconds)\")\n\nfig, axes = plt.subplots(4, 1, figsize=(14, 12), sharex=True, constrained_layout=True)\n\nsess[\"filled_price\"].plot(ax=axes[0], linewidth=0.6)\naxes[0].set_ylabel(\"filled_price\")\naxes[0].set_title(f\"{PLOT_SYMBOL} — {latest_session}\")\n\nsess[\"log_return\"].plot(ax=axes[1], linewidth=0.5, alpha=0.8)\naxes[1].axhline(0, color=\"black\", linewidth=0.5)\naxes[1].set_ylabel(\"log_return\")\n\nsess[[\"rv_past_60\", \"rv_next_60\"]].plot(ax=axes[2], linewidth=0.7)\naxes[2].set_ylabel(\"Realized Vol\")\n\nsess[\"n_events\"].plot(ax=axes[3], linewidth=0.6, alpha=0.8)\naxes[3].set_ylabel(\"n_events / s\")\n\nfig.autofmt_xdate(rotation=30)\nplt.show()\n\n# resample to 5-minute bars\nsess_5m = sess[[\"n_events\", \"n_trade\", \"rv_past_60\"]].resample(\"5min\").agg({\n    \"n_events\":   \"sum\",\n    \"n_trade\":    \"sum\",\n    \"rv_past_60\": \"last\",\n})\nfig2, ax2 = plt.subplots(figsize=(14, 3), constrained_layout=True)\nsess_5m[[\"n_events\", \"n_trade\"]].plot(\n    kind=\"bar\", edgecolor=\"none\", ax=ax2,\n    title=f\"{PLOT_SYMBOL} — event counts resampled to 5-minute bars\"\n)\nax2.set_ylabel(\"count\")\nax2.set_xticks([])\nplt.show()","key":"roVyG6D1Br"},{"type":"outputs","id":"iEyVeLio3OoPqgjsPsRDw","children":[{"type":"output","jupyter_data":{"name":"stdout","output_type":"stream","text":"6E.c.0 — 2026-01-15  (75,919 seconds)\n"},"children":[],"key":"atlgz3GIOH"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1680x1440 with 4 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"ddc2c11dd3eece166430696f69862416","path":"/cme-vol-research.github.io/build/ddc2c11dd3eece166430696f69862416.png"}}},"children":[],"key":"jconz5eLeK"},{"type":"output","jupyter_data":{"output_type":"display_data","metadata":{},"data":{"text/plain":{"content":"<Figure size 1680x360 with 1 Axes>","content_type":"text/plain"},"image/png":{"content_type":"image/png","hash":"4c41b5cdda7c6d240c51fd2e51fc8547","path":"/cme-vol-research.github.io/build/4c41b5cdda7c6d240c51fd2e51fc8547.png"}}},"children":[],"key":"SRra4NJGGB"}],"key":"oiTsng8nfY"}],"key":"ZY7E21CoFM"}],"key":"HAhlL6rJqx"},"references":{"cite":{"order":["Zhang_2021"],"data":{"Zhang_2021":{"label":"Zhang_2021","enumerator":"1","doi":"10.1080/1350486x.2021.1967767","html":"Zhang, Z., Lim, B., & Zohren, S. (2021). Deep Learning for Market by Order Data. <i>Applied Mathematical Finance</i>, <i>28</i>(1), 79–95. <a target=\"_blank\" rel=\"noreferrer\" href=\"https://doi.org/10.1080/1350486x.2021.1967767\">10.1080/1350486x.2021.1967767</a>","url":"https://doi.org/10.1080/1350486x.2021.1967767"}}}},"footer":{"navigation":{"prev":{"title":"Load MBO csv files from S3 into Spark","url":"/aws-l3-wrangling","group":"Data Pipeline"}}},"domain":"http://localhost:3001"}